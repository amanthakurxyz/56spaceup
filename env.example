# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-app.region.insforge.app

# Anonymous key (optional, only needed for database/storage operations)
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# Server-only API key for secure relay (never exposed to client bundle)
INSFORGE_API_KEY=your_insforge_api_key_here
